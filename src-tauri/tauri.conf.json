{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "direc-tree",
	"version": "0.1.0",
	"identifier": "com.rishabh.directree",
	"build": {
		"frontendDist": "../out",
		"devUrl": "http://localhost:3000",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"plugins": {
		"clipboard_manager": {
			"permissions" : ["clipboard-manager:allow-write-text"],
			"allow-write-text" : true
		}
	},
	"app": {
		"windows": [
			{
				"title": "DirecTree",
				"width": 800,
				"height": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
